# Local development configuration.
# Do not put real API keys in this file.

RUST_LOG=rustygate=debug,tower_http=info
RUSTYGATE_CONFIG=config/gateway.example.toml

# Optional real-provider credentials for config/gateway.live.example.toml.
OPENAI_API_KEY=your-openai-api-key
