# Local development configuration.
# Do not put real API keys in this file.

RUST_LOG=rustygate=debug,tower_http=info
RUSTYGATE_CONFIG=config/gateway.local.toml
RUSTYGATE_GATEWAY_API_KEY=local-dev-gateway-key

# Other profiles:
# RUSTYGATE_CONFIG=config/gateway.staging.toml
# RUSTYGATE_CONFIG=config/gateway.prod.toml

# Optional real-provider credentials for live, staging, or prod profiles.
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
